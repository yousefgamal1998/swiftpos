+<script setup lang="ts">
+import { computed, onMounted, onUnmounted, ref } from 'vue';
+
+const props = withDefaults(
+    defineProps<{
+        align?: 'left' | 'right';
+        width?: '48' | '56';
+        contentClasses?: string;
+    }>(),
+    {
+        align: 'right',
+        width: '48',
+        contentClasses: 'py-1 bg-white',
+    },
+);
+
